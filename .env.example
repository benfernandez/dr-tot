# Anthropic — from console.anthropic.com
ANTHROPIC_API_KEY=

# Supabase — from Project Settings → API
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# SendBlue — run `sendblue login` + `sendblue show-keys` + `sendblue lines`
# to get these. Free tier uses a shared number, paid tiers get a dedicated
# line. Free tier note: contacts must text this number FIRST before we can
# reach them (no cold outbound).
SENDBLUE_API_KEY=
SENDBLUE_API_SECRET=
SENDBLUE_FROM_NUMBER=
# Optional. If Sendblue signs webhooks via an sb-signing-secret header, put
# the shared secret here. Leave blank to skip signature verification (fine
# for testing; tighten before paid launch).
SENDBLUE_SIGNING_SECRET=

# Stripe — from dashboard.stripe.com/apikeys and dashboard.stripe.com/products
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=

# Meta Conversion API — from Events Manager → Dataset → Settings
META_PIXEL_ID=
META_CAPI_ACCESS_TOKEN=
# Optional — paste the test event code from Events Manager → Test Events to
# verify events in real time without publishing.
META_TEST_EVENT_CODE=

# Public URLs
PUBLIC_APP_URL=https://doctortot.com
# Comma-separated origins allowed to call /api/*
ALLOWED_ORIGINS=https://doctortot.com,https://app.doctortot.com

# HTTP port for the backend
PORT=3000

# Proactive check-in hour (0-23, user-local). Default noon — per-friends
# feedback, morning appetite is too low to engage. Shift by setting this.
CHECKIN_HOUR=12

# Session signing secret for account-portal magic-code auth.
# Generate: `openssl rand -hex 32`
SESSION_SECRET=

# Optional
NODE_ENV=development
LOG_LEVEL=info

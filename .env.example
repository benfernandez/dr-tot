# Anthropic — from console.anthropic.com
ANTHROPIC_API_KEY=

# Supabase — from Project Settings → API
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# SendBlue — from dashboard.sendblue.com
# (Provisions 1 phone line that handles iMessage primary + SMS fallback.)
SENDBLUE_API_KEY=
SENDBLUE_API_SECRET=
# Shared secret configured on each webhook in the SendBlue dashboard.
# Sent back to us in the sb-signing-secret header for verification.
SENDBLUE_SIGNING_SECRET=

# Public URL for the account portal (destructive actions redirect here)
PUBLIC_APP_URL=https://drtot.app

# HTTP port for the webhook server
PORT=3000

# Optional
NODE_ENV=development
LOG_LEVEL=info

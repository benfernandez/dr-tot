# Telegram — from @BotFather
TELEGRAM_BOT_TOKEN=

# Anthropic — from console.anthropic.com
ANTHROPIC_API_KEY=

# Supabase — from Project Settings → API
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# SMS/iMessage (Phase B — leave blank for now)
# SendBlue — primary channel, from dashboard.sendblue.com
SENDBLUE_API_KEY=
SENDBLUE_API_SECRET=

# Telnyx — SMS fallback, from portal.telnyx.com
TELNYX_API_KEY=
TELNYX_MESSAGING_PROFILE_ID=
TELNYX_FROM_NUMBER=

# Public URL of the account portal (for destructive-intent redirects)
PUBLIC_APP_URL=https://drtot.app

# Port the webhook server listens on (Phase B)
PORT=3000

# Optional
NODE_ENV=development
LOG_LEVEL=info

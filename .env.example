# Anthropic — from console.anthropic.com
ANTHROPIC_API_KEY=

# Supabase — from Project Settings → API
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# SendBlue — run `sendblue login` + `sendblue show-keys` + `sendblue lines`
# to get these from the CLI. Free tier uses a shared number, paid tiers get
# a dedicated line. Free tier note: contacts must text this number FIRST
# before we can reach them (no cold outbound).
SENDBLUE_API_KEY=
SENDBLUE_API_SECRET=
SENDBLUE_FROM_NUMBER=
# Optional. If Sendblue signs webhooks via an sb-signing-secret header, put
# the shared secret here. Leave blank to skip signature verification (fine
# for testing; tighten before paid launch).
SENDBLUE_SIGNING_SECRET=

# Public URL for the account portal (destructive actions redirect here)
PUBLIC_APP_URL=https://drtot.app

# HTTP port for the webhook server
PORT=3000

# Optional
NODE_ENV=development
LOG_LEVEL=info

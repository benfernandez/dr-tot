{
  "env": {
    "RAILWAY_API_TOKEN": "46c22208-234f-4df5-b477-55ebfb0fa3b1"
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/install-clis.sh"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(.claude/hooks/install-clis.sh)",
      "Bash(railway whoami)",
      "Bash(railway status:*)",
      "Bash(railway logs:*)",
      "Bash(railway variables:*)",
      "Bash(railway list:*)",
      "Bash(railway environment:*)",
      "Bash(railway service:*)",
      "Bash(railway run:*)",
      "Bash(npm run errors:*)",
      "Bash(npm run typecheck:*)",
      "Bash(npm run build:*)"
    ]
  }
}

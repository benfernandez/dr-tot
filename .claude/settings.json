{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/install-clis.sh"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(.claude/hooks/install-clis.sh)",
      "Bash(railway whoami)",
      "Bash(railway status:*)",
      "Bash(railway logs:*)",
      "Bash(railway variables:*)",
      "Bash(railway list:*)",
      "Bash(railway environment:*)",
      "Bash(railway service:*)",
      "Bash(supabase --version)",
      "Bash(supabase projects:*)",
      "Bash(supabase inspect:*)",
      "Bash(supabase functions list:*)",
      "Bash(supabase functions logs:*)",
      "Bash(supabase db dump:*)",
      "Bash(supabase db diff:*)",
      "Bash(supabase migration list:*)",
      "Bash(npm run typecheck:*)",
      "Bash(npm run build:*)"
    ]
  }
}

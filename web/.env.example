# Next.js (Vercel) — all public vars start with NEXT_PUBLIC_

# URL of the Dr. Tot backend (Railway). Landing + portal call this.
NEXT_PUBLIC_API_BASE_URL=https://api.doctortot.com

# Meta Pixel ID — drops the client-side pixel in the layout. Leave blank to
# disable pixel entirely (useful in dev).
NEXT_PUBLIC_META_PIXEL_ID=

# Your Sendblue phone number — used on the thank-you page for the sms: deep link.
# Must match SENDBLUE_FROM_NUMBER in the backend.
NEXT_PUBLIC_SENDBLUE_NUMBER=+15551234567
